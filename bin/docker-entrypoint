#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
  LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
  export LD_PRELOAD
fi

# Enable running db:prepare for production server boot
# DIRECT_DATABASE_URL（PgBouncer 非経由）でマイグレーションを実行する
if [ "${1}" == "bundle" ] && [ "${2}" == "exec" ] && [ "${3}" == "puma" ]; then
  echo "Running db:prepare with direct connection..."
  DATABASE_URL="${DIRECT_DATABASE_URL:-$DATABASE_URL}" ./bin/rails db:prepare
fi

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  DATABASE_URL="${DIRECT_DATABASE_URL:-$DATABASE_URL}" ./bin/rails db:prepare
fi

exec "${@}"
